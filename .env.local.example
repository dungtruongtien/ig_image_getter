# Google reCAPTCHA v2 — get keys at https://www.google.com/recaptcha/admin
# Site key is public (used in frontend)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Secret key is private (used in server-side verification only)
RECAPTCHA_SECRET=your-recaptcha-secret-key

# Google AdSense — get your publisher ID at https://adsense.google.com
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# Your deployed site URL (no trailing slash) — used for canonical, sitemap, OG tags
NEXT_PUBLIC_SITE_URL=https://instadown.co

# Ouo.io link shortener for monetization — get key at https://ouo.io → Dashboard → API
# If not set, links fall back to direct proxy URL (safe for dev)
OUO_API_KEY=your_ouo_api_key_here
